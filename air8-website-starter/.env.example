# ------------------------------------------------------------
# Copy this file to ".env" and fill in real values.
# NEVER commit the real .env to GitHub (it holds your password).
# The .gitignore already blocks it.
#
# These are only needed when you want the contact form to actually
# EMAIL you. Without them, the site still runs and logs messages.
# ------------------------------------------------------------

# --- How the contact form emails you ---------------------------------
#
# PREFERRED: Brevo's HTTP API. Railway blocks outbound SMTP entirely (every
# port times out — 465 to cPanel, 587 to Brevo's own relay), so SMTP cannot
# work there no matter the credentials. The API is plain HTTPS on port 443,
# which nothing blocks. Get the key from Brevo -> SMTP & API -> API keys.
BREVO_API_KEY=

# FALLBACK: classic SMTP, used only when BREVO_API_KEY is empty. Fine locally
# or on a host that permits outbound SMTP.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# The address enquiries appear to come FROM. With a relay this differs from
# SMTP_USER (which is just a login), so set it to a real address on your own
# domain and authenticate that domain with the relay. Defaults to SMTP_USER.
MAIL_FROM=sales@air8industries.com

# Where enquiries should be delivered.
CONTACT_TO=sales@air8industries.com

# PORT is set automatically by Render/Railway. Leave blank locally.
# PORT=3000

# Set on Render/Railway only (never locally). Enables secure/httpOnly
# cookies and "trust proxy" — without it, admin login will fail behind
# their HTTPS reverse proxy.
# NODE_ENV=production

# ------------------------------------------------------------
# Database (air8_db.sql imported into MariaDB/MySQL — e.g. via
# XAMPP/phpMyAdmin locally). Products, categories and inquiries
# (contact/inquiry messages) are stored here.
# ------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=air8_db

# ------------------------------------------------------------
# Admin panel (/admin.html) — one shared password, no user table.
# Change this to something real before you deploy.
# ------------------------------------------------------------
ADMIN_PASSWORD=changeme
SESSION_SECRET=change-this-to-a-long-random-string
